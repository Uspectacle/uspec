{
  "plugins": [],
  "parserOptions": {
    "project": ["apps/backend/tsconfig.*?.json"]
  },
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "import/prefer-default-export": "off",
        "class-methods-use-this": "off",
        "no-void": "off",
        "no-restricted-syntax": "off",
        "no-constant-condition": "off",
        "no-await-in-loop" : "off"
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    }
  ]
}
